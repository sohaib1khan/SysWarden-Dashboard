# ─────────────────────────────────────────
# Backend
# ─────────────────────────────────────────

# A cryptographically random 64-char string — generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_random_64_char_hex_string

# SQLite (default) — change to postgresql+psycopg2://user:pass@host/db for TimescaleDB
DATABASE_URL=sqlite:////app/data/syswarden.db

# Comma-separated list of allowed dashboard origins (no trailing slash, no wildcard in production)
ALLOWED_ORIGINS=http://localhost:5173

# JWT expiry
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate limiting (per IP, applied to ingest + fetch endpoints)
RATE_LIMIT=60/minute

# ─────────────────────────────────────────
# Agent  (set on the host running the agent)
# ─────────────────────────────────────────
SYSWARDEN_BACKEND_URL=http://localhost:8000

# Populated automatically on first run — or inject manually to skip registration
SYSWARDEN_API_KEY=
SYSWARDEN_AGENT_ID=

# How often (seconds) to push metrics
SYSWARDEN_INTERVAL=10
